# =============================================================================
# dotclaude — .gitignore
# =============================================================================
# Aggressive: blocks runtime ephemera, secrets, and PII. Anything Claude Code
# regenerates on session start is ignored.
#
# Comments live on their own lines — git's gitignore parser does NOT support
# trailing inline comments (the comment becomes part of the pattern).
#
# Run `git status --ignored` to audit what's hidden.

# ── Runtime / cache (regenerated by Claude Code) ────────────────────────────
_archives/
backups/
cache/
debug/
downloads/
file-history/
paste-cache/
plugins/
projects/
security/
session-env/
sessions/
shell-snapshots/
statsig/
tasks/
telemetry/
todos/
agent-memory/

# ── Per-session ephemera ────────────────────────────────────────────────────
history.jsonl
.last-cleanup
.last-update-result.json
.last-self-update
stats-cache.json
mcp-needs-auth-cache.json

# ── Background daemon / job runtime ─────────────────────────────────────────
# Regenerated each session. daemon/control.key is a credential and daemon.log
# carries auth tokens — never commit these.
daemon/
daemon.lock
daemon.log
daemon.status.json
jobs/
gh-pr-status-cache.json

# auto-generated session plan files
plans/

# session-local context log
context-log.md

# hook event journal (PII-light but still local-only)
hooks/logs/

# ── Secrets and PII ─────────────────────────────────────────────────────────
.credentials.json
.env
.env.local
.env.presenton
.env.*
!.env.example

# real PII; identity.example.md is the committed template
identity.md

# real persona; profile.example.md is the committed template
profile.md

settings.local.json
hooks/config/hooks-config.local.json
!hooks/config/hooks-config.local.example.json

# Symlink to a private brain dir; not part of dotclaude
brain

# Symlink to an external skills dir on Desktop; not part of dotclaude
skills/qualify-leads

# Nested git repo for the synthese skill — user installs manually
# (see skills/EXTERNAL.md). Not auto-installed: submodule integration
# was rejected because submodule lifecycle scripts run on clone.
skills/synthese/

# FR-B2B sales-enablement skills — excluded from the public flagship (client-confidential)
skills/voice-check/
skills/deck-generator/
skills/humanize-fr/
skills/linkedin-post/

# ── Stale backups ───────────────────────────────────────────────────────────
settings.json.bak
settings.json.orig
*.bak
*.orig

# ── Editor / OS ─────────────────────────────────────────────────────────────
.DS_Store
*.swp
*~
.idea/
.vscode/

# ── Python (in case any inline script ever generates one) ───────────────────
__pycache__/
*.py[cod]
.venv/
venv/
.pytest_cache/
.ruff_cache/

# ── Node (same reasoning) ───────────────────────────────────────────────────
node_modules/
npm-debug.log*
.pnpm-debug.log*

# deep-research newsletter corpus — derived/cloned data, regenerated by sync-newsletter-corpus.sh
deep-research/newsletter-corpus/
deep-research/newsletter-corpus-src/

# user-scope expert prior — PRIVATE, contains personal GitHub handles
deep-research/experts.yaml

# subagent-driven-development scratch ledger (never publish)
.superpowers/

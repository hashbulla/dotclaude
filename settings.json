{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "respectGitignore": true,
  "env": {
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80",
    "POSTHOG_API_KEY": "${POSTHOG_API_KEY}",
    "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude Opus 4.7 (1M context) <noreply@anthropic.com>",
    "pr": "🤖 Generated with [Claude Code](https://claude.com/claude-code)"
  },
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(gh repo view:*)",
      "Bash(gh pr view:*)",
      "Bash(gh issue view:*)",
      "Read",
      "Glob",
      "Grep",
      "mcp__codegraph__codegraph_search",
      "mcp__codegraph__codegraph_context",
      "mcp__codegraph__codegraph_callers",
      "mcp__codegraph__codegraph_callees",
      "mcp__codegraph__codegraph_impact",
      "mcp__codegraph__codegraph_node",
      "mcp__codegraph__codegraph_status"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Read(path: **/.env)",
      "Read(path: **/.env.*)",
      "Read(path: **/.env.local)",
      "Read(path: **/config/secrets.*)",
      "Read(path: **/*.key)",
      "Read(path: **/*.pem)",
      "Read(path: **/credentials.json)",
      "Read(path: **/.aws/credentials)",
      "Read(path: **/.ssh/id_*)"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PreToolUse",
            "timeout": 5000,
            "statusMessage": "PreToolUse",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PostToolUse",
            "timeout": 5000,
            "statusMessage": "PostToolUse",
            "async": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pdf-design-gate.sh",
            "timeout": 15,
            "statusMessage": "Checking for PDF output"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PostToolUseFailure",
            "timeout": 5000,
            "statusMessage": "PostToolUseFailure",
            "async": true
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PermissionRequest",
            "timeout": 5000,
            "statusMessage": "PermissionRequest",
            "async": true
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PermissionDenied",
            "timeout": 5000,
            "statusMessage": "PermissionDenied",
            "async": true
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py UserPromptSubmit",
            "timeout": 5000,
            "statusMessage": "UserPromptSubmit",
            "async": true
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py Notification",
            "timeout": 5000,
            "statusMessage": "Notification",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py Stop",
            "timeout": 5000,
            "statusMessage": "Stop",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py StopFailure",
            "timeout": 5000,
            "statusMessage": "StopFailure",
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py SubagentStart",
            "timeout": 5000,
            "statusMessage": "SubagentStart",
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py SubagentStop",
            "timeout": 5000,
            "statusMessage": "SubagentStop",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PreCompact",
            "timeout": 5000,
            "statusMessage": "PreCompact",
            "once": true,
            "async": true
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py PostCompact",
            "timeout": 5000,
            "statusMessage": "PostCompact",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py SessionStart",
            "timeout": 5000,
            "statusMessage": "SessionStart",
            "once": true,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py SessionEnd",
            "timeout": 5000,
            "statusMessage": "SessionEnd",
            "once": true,
            "async": true
          }
        ]
      }
    ],
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py Setup",
            "timeout": 30000,
            "statusMessage": "Setup",
            "async": true
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py TeammateIdle",
            "timeout": 5000,
            "statusMessage": "TeammateIdle",
            "async": true
          }
        ]
      }
    ],
    "TaskCreated": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py TaskCreated",
            "timeout": 5000,
            "statusMessage": "TaskCreated",
            "async": true
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py TaskCompleted",
            "timeout": 5000,
            "statusMessage": "TaskCompleted",
            "async": true
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py ConfigChange",
            "timeout": 5000,
            "statusMessage": "ConfigChange",
            "async": true
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-create.sh",
            "timeout": 120
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py WorktreeCreate",
            "timeout": 5000,
            "statusMessage": "WorktreeCreate",
            "async": true
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-remove.sh",
            "timeout": 60
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py WorktreeRemove",
            "timeout": 5000,
            "statusMessage": "WorktreeRemove",
            "async": true
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py InstructionsLoaded",
            "timeout": 5000,
            "statusMessage": "InstructionsLoaded",
            "async": true
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py Elicitation",
            "timeout": 5000,
            "statusMessage": "Elicitation",
            "async": true
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py ElicitationResult",
            "timeout": 5000,
            "statusMessage": "ElicitationResult",
            "async": true
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py CwdChanged",
            "timeout": 5000,
            "statusMessage": "CwdChanged",
            "async": true
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".envrc|.env|.env.local",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py FileChanged",
            "timeout": 5000,
            "statusMessage": "FileChanged",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "npx -y ccstatusline@latest",
    "padding": 0,
    "refreshInterval": 10
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "telegram@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true
  },
  "outputStyle": "Explanatory",
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Reasoning",
      "Synthesizing",
      "Cross-referencing",
      "Verifying assumptions",
      "Building the model",
      "Tracing the dependency graph",
      "Auditing the diff",
      "Composing the response",
      "Tightening the prose",
      "Citing sources"
    ]
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark-daltonized",
  "agentPushNotifEnabled": true,
  "_documentation": "Full doctrine at best-practice/claude-settings.md. Secrets via .env.local (gitignored). Hooks at hooks/scripts/hooks.py.",
  "ignorePatterns": [
    ".env",
    ".env.*",
    "**/__pycache__/**",
    "**/.venv/**",
    "**/node_modules/**"
  ],
  "mcpServers": {
    "mcp-mermaid": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-mermaid"
      ]
    },
    "posthog": {
      "command": "npx",
      "args": [
        "-y",
        "@posthog/agent-toolkit",
        "mcp"
      ],
      "env": {
        "POSTHOG_API_KEY": "${POSTHOG_API_KEY}",
        "POSTHOG_BASE_URL": "https://eu.posthog.com"
      }
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
      }
    }
  }
}

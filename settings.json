    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-create.sh",
            "timeout": 120
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py WorktreeCreate",
            "timeout": 5000,
            "async": true,
            "statusMessage": "WorktreeCreate"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/worktree-remove.sh",
            "timeout": 60
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py WorktreeRemove",
            "timeout": 5000,
            "async": true,
            "statusMessage": "WorktreeRemove"
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py InstructionsLoaded",
            "timeout": 5000,
            "async": true,
            "statusMessage": "InstructionsLoaded"
          }
        ]
      }
    ],
    "Elicitation": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py Elicitation",
            "timeout": 5000,
            "async": true,
            "statusMessage": "Elicitation"
          }
        ]
      }
    ],
    "ElicitationResult": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py ElicitationResult",
            "timeout": 5000,
            "async": true,
            "statusMessage": "ElicitationResult"
          }
        ]
      }
    ],
    "CwdChanged": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py CwdChanged",
            "timeout": 5000,
            "async": true,
            "statusMessage": "CwdChanged"
          }
        ]
      }
    ],
    "FileChanged": [
      {
        "matcher": ".envrc|.env|.env.local",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PROJECT_DIR:-$HOME/.claude}/hooks/scripts/hooks.py FileChanged",
            "timeout": 5000,
            "async": true,
            "statusMessage": "FileChanged"
          }
        ]
      }
    ]
  }
}
